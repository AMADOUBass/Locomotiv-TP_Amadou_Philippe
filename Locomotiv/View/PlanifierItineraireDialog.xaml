<Window x:Class="Locomotiv.View.PlanifierItineraireDialog "
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Locomotiv"
        xmlns:enumUtils="clr-namespace:Locomotiv.Utils.EnumUtils"
        Title="Ajouter un Train" Height="300" Width="400"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="Sélectionner un train:"/>
        <ComboBox x:Name="cmbTrain"
                  DisplayMemberPath="Nom"
                  SelectedValuePath="Id"
                  Margin="0,5"/>

        <TextBlock Text="Ajouter des arrêts (stations ou points d’intérêt):" Margin="10,10,0,0"/>
        <ListBox x:Name="lstArrets"
                 DisplayMemberPath="Nom"
                 SelectionMode="Multiple"
                 Height="150"/>

        <CheckBox x:Name="chkRespecteRegles" Content="Respecter les règles de sécurité" Margin="0,10"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Planifier" Click="BtnValider_Click" Margin="0,0,10,0"/>
            <Button Content="Annuler" Click="BtnAnnuler_Click"/>
        </StackPanel>
    </StackPanel>

</Window>